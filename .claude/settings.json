{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/private/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.kdbx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/*.ppk)",
      "Read(**/*.p8)",

      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/secrets/**)",
      "Edit(**/credentials/**)",
      "Edit(**/private/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(**/id_rsa)",
      "Edit(**/id_rsa.*)",
      "Edit(**/id_ed25519)",
      "Edit(**/id_ed25519.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/*.kdbx)",
      "Edit(**/*.jks)",
      "Edit(**/*.keystore)",
      "Edit(**/*.ppk)",
      "Edit(**/*.p8)",

      "Write(.env)",
      "Write(.env.*)",
      "Write(**/secrets/**)",
      "Write(**/credentials/**)",
      "Write(**/private/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.config/gcloud/**)",
      "Write(**/id_rsa)",
      "Write(**/id_rsa.*)",
      "Write(**/id_ed25519)",
      "Write(**/id_ed25519.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/*.kdbx)",
      "Write(**/*.jks)",
      "Write(**/*.keystore)",
      "Write(**/*.ppk)",
      "Write(**/*.p8)",

      "MultiEdit(.env)",
      "MultiEdit(.env.*)",
      "MultiEdit(**/secrets/**)",
      "MultiEdit(**/credentials/**)",
      "MultiEdit(**/private/**)",
      "MultiEdit(~/.ssh/**)",
      "MultiEdit(~/.aws/**)",
      "MultiEdit(~/.config/gcloud/**)",
      "MultiEdit(**/id_rsa)",
      "MultiEdit(**/id_rsa.*)",
      "MultiEdit(**/id_ed25519)",
      "MultiEdit(**/id_ed25519.*)",
      "MultiEdit(**/*.pem)",
      "MultiEdit(**/*.key)",
      "MultiEdit(**/*.p12)",
      "MultiEdit(**/*.pfx)",
      "MultiEdit(**/*.kdbx)",
      "MultiEdit(**/*.jks)",
      "MultiEdit(**/*.keystore)",
      "MultiEdit(**/*.ppk)",
      "MultiEdit(**/*.p8)",

      "NotebookEdit(.env)",
      "NotebookEdit(.env.*)",
      "NotebookEdit(**/secrets/**)",
      "NotebookEdit(**/credentials/**)",
      "NotebookEdit(**/private/**)",
      "NotebookEdit(~/.ssh/**)",
      "NotebookEdit(~/.aws/**)",
      "NotebookEdit(~/.config/gcloud/**)",
      "NotebookEdit(**/id_rsa)",
      "NotebookEdit(**/id_rsa.*)",
      "NotebookEdit(**/id_ed25519)",
      "NotebookEdit(**/id_ed25519.*)",
      "NotebookEdit(**/*.pem)",
      "NotebookEdit(**/*.key)",
      "NotebookEdit(**/*.p12)",
      "NotebookEdit(**/*.pfx)",
      "NotebookEdit(**/*.kdbx)",
      "NotebookEdit(**/*.jks)",
      "NotebookEdit(**/*.keystore)",
      "NotebookEdit(**/*.ppk)",
      "NotebookEdit(**/*.p8)",

      "Edit(/docs/05_RISK_POLICY.md)",
      "Write(/docs/05_RISK_POLICY.md)",
      "MultiEdit(/docs/05_RISK_POLICY.md)",

      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin HEAD:main *)",

      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease *)",

      "Bash(gh pr merge)",
      "Bash(gh pr merge *)",

      "Bash(gh repo edit)",
      "Bash(gh repo edit *)",

      "Bash(rm -rf)",
      "Bash(rm -rf *)",
      "Bash(rm -fr)",
      "Bash(rm -fr *)",

      "mcp__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/policy_guard.py"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
